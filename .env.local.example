# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Google OAuth (from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Upstash Redis (for passkey storage — free tier at upstash.com)
# 1. Create free account at console.upstash.com
# 2. Create a Redis database (any region)
# 3. Copy REST URL and Token from the database page
# Works with both KV_REST_API_* and UPSTASH_REDIS_REST_* env var names
UPSTASH_REDIS_REST_URL=your-upstash-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Vercel API (for stats widget — deployment counts, project stats)
# Create at: vercel.com/account/tokens
VERCEL_TOKEN=your-vercel-api-token
VERCEL_TEAM_ID=team_OuODA23GunZTZvhNNMQ2IDYP

# Domain (for WebAuthn relying party)
NEXT_PUBLIC_DOMAIN=willgates.dev
